# Do not commit real keys. Copy to .env.local or set these in your shell.

# Mimo Anthropic-compatible endpoint:
ANTHROPIC_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
ANTHROPIC_AUTH_TOKEN=replace_me
ANTHROPIC_MODEL=mimo-v2.5-pro
ANTHROPIC_DEFAULT_SONNET_MODEL=mimo-v2.5-pro
ANTHROPIC_DEFAULT_OPUS_MODEL=mimo-v2.5-pro
ANTHROPIC_DEFAULT_HAIKU_MODEL=mimo-v2.5-pro

# Mimo OpenAI-compatible endpoint:
MIMO_OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_DEFAULT_MODEL=mimo-v2.5-pro
MIMO_VISION_MODEL=mimo-v2.5

# Optional providers:
OPENAI_API_KEY=replace_me
DASHSCOPE_API_KEY=replace_me
OPENROUTER_API_KEY=replace_me

# Gateway remote access. Do not put real tokens in Git.
# Loopback requests are allowed by default for local development.
ATM_GATEWAY_TOKEN=replace_me
ATM_ALLOWED_ORIGINS=http://127.0.0.1:7870,http://localhost:7870
# ATM_GATEWAY_REQUIRE_TOKEN_FOR_LOOPBACK=false
# ATM_ALLOW_REMOTE_NO_AUTH=false
